APP_NAME="Likha PH"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database, mail, etc. — copy from your host or run php artisan key:generate after clone.

# Google OAuth (Laravel Socialite) — enables “Continue with Google” on login/register.
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly: ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
